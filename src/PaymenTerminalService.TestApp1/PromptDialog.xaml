<Window x:Class="PaymentTerminalService.TestApp1.PromptDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Terminal Prompt" SizeToContent="WidthAndHeight"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner"
        MinWidth="340">
    <StackPanel Margin="16" Width="320">
        <TextBlock x:Name="MessageText"
                   TextWrapping="Wrap"
                   FontWeight="SemiBold"
                   Margin="0,0,0,10"/>
        <TextBlock x:Name="HintText"
                   TextWrapping="Wrap"
                   Foreground="Gray"
                   FontSize="11"
                   Margin="0,0,0,8"
                   Visibility="Collapsed"/>
        <TextBox x:Name="InputTextBox"
                 Margin="0,0,0,6"
                 Visibility="Collapsed"
                 PreviewTextInput="InputTextBox_PreviewTextInput"/>
        <TextBlock x:Name="ValidationText"
                   Foreground="Red"
                   FontSize="11"
                   Margin="0,0,0,8"
                   Visibility="Collapsed"/>
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,4,0,0">
            <Button x:Name="OkButton"
                    Width="75"
                    Margin="0,0,8,0"
                    Click="OkButton_Click"/>
            <Button x:Name="CancelButton"
                    Width="75"
                    Click="CancelButton_Click"/>
        </StackPanel>
    </StackPanel>
</Window>